# UrbanFix Environment Variables
# Copy this file to .env.local and fill in your values

# ===========================================
# SUPABASE CONFIGURATION
# ===========================================
# Get these from your Supabase project settings > API Keys
# https://supabase.com/dashboard/project/_/settings/api-keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Publishable Key (client-side safe, replaces deprecated anon key)
# Format: sb_publishable_...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Secret Key (server-side only, replaces deprecated service_role key)
# Format: sb_secret_...
# Used for admin operations like creating NGO accounts
SUPABASE_SECRET_KEY=your-secret-key

# ===========================================
# GOOGLE MAPS CONFIGURATION
# ===========================================
# Get from Google Cloud Console > APIs & Services > Credentials
# Enable: Maps JavaScript API, Geocoding API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Duplicate detection settings
NEXT_PUBLIC_DUPLICATE_RADIUS_METERS=50
NEXT_PUBLIC_DUPLICATE_WINDOW_DAYS=7

# ===========================================
# OPTIONAL: DEVELOPMENT SETTINGS
# ===========================================
# Set to 'true' to enable debug logging
# NEXT_PUBLIC_DEBUG=false
